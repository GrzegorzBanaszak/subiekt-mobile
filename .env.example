# Główny origin frontendu dopuszczony przez CORS (bez ukośnika na końcu).
APP_ORIGIN=https://subiekt.example.com

# PostgreSQL aplikacji
APPLICATION_DB_NAME=subiekt_mobile
APPLICATION_DB_USER=subiekt_mobile
APPLICATION_DB_PASSWORD=ZMIEŃ_NA_SILNE_LOSOWE_HASŁO

# Konto SQL Server powinno mieć wyłącznie uprawnienia do odczytu bazy Subiekta GT.
# Dla certyfikatu z lokalnego SQL Servera może być potrzebne TrustServerCertificate=True.
SUBIEKT_GT_CONNECTION_STRING=Server=192.168.1.10,1433;Database=NAZWA_BAZY;User Id=subiekt_mobile_ro;Password=ZMIEŃ_HASŁO;Encrypt=True;TrustServerCertificate=True

# Opcjonalny, jednorazowy bootstrap konta root. Ustaw wszystkie trzy wartości albo pozostaw puste.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
BOOTSTRAP_ADMIN_PASSWORD=ZMIEŃ_NA_SILNE_HASŁO_MINIMUM_12_ZNAKÓW

# Token z Cloudflare Zero Trust > Networks > Tunnels.
CLOUDFLARE_TUNNEL_TOKEN=WKLEJ_TOKEN_TUNELU
